  window-resize {
    spring damping-ratio=0.45 stiffness=750 epsilon=0.0001
  }

  config-notification-open-close {
    spring damping-ratio=0.45 stiffness=750 epsilon=0.0001
  }

  exit-confirmation-open-close {
    spring damping-ratio=0.60 stiffness=600 epsilon=0.001
  }

  screenshot-ui-open {
    duration-ms 200
    curve "ease-out-quad"
  }

  overview-open-close {
    spring damping-ratio=0.35 stiffness=900 epsilon=0.0001
  }

  recent-windows-close {
    spring damping-ratio=0.40 stiffness=900 epsilon=0.001
  }
