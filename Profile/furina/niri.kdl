  // }

  window-close {
    duration-ms 200
    curve "linear"
    custom-shader r"
    const float PI = 3.14159265358979;

    // ── Easing ────────────────────────────────────────────────────────
    float easeInExpo(float t)   { return t == 0.0 ? 0.0 : pow(2.0, 10.0*(t-1.0)); }
    float easeOutExpo(float t)  { return t == 1.0 ? 1.0 : 1.0 - pow(2.0,-10.0*t); }
    float easeInQuad(float t)   { return t*t; }
    float easeOutQuad(float t)  { return 1.0-(1.0-t)*(1.0-t); }
    float easeInCubic(float t)  { return t*t*t; }
    float easeOutCubic(float t) { float f=t-1.0; return f*f*f+1.0; }
    float easeInQuart(float t)  { return t*t*t*t; }

    float saturate(float x) { return clamp(x,0.0,1.0); }

    float remap(float t, float a, float b) {
      return saturate((t-a)/(b-a));
    }

    vec2 scaleUV(vec2 uv, vec2 scale) {
      return (uv-0.5)/scale + 0.5;
    }

    float centerGradient(float x) {
      x *= 2.0;
      return x < 1.0 ? x : 2.0-x;
    }

    vec2 barrelDistort(vec2 uv, float strength) {
      vec2 cc = uv - 0.5;
      float dist = dot(cc,cc);
      return uv + cc * dist * strength;
    }

    // ── Main ──────────────────────────────────────────────────────────
    vec4 close_color(vec3 coords_geo, vec3 size_geo) {

      if (coords_geo.x < 0.0 || coords_geo.x > 1.0 ||
      coords_geo.y < 0.0 || coords_geo.y > 1.0)
      return vec4(0.0);

      vec2 uv = (niri_geo_to_tex * coords_geo).xy;

      if (uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0)
      return vec4(0.0);

      float p = niri_clamped_progress; // 0=open, 1=closed

      // ── Invert progress for 'closing' direction ───────────────────
      float inv = 1.0 - p;

      // ── Phase timings (y closes faster than x, like real CRT) ────
      float py = remap(inv, 0.30, 1.00); // y: close by 70% of anim
      float px = remap(inv, 0.00, 0.80); // x: close by 100%

      float scaleX = mix(0.06, 1.0, easeOutCubic(px));
      float scaleY = mix(0.0,  1.0, easeInQuad(py));

      float barrelStr = (1.0 - easeOutQuad(px)) * 0.20;
      vec2 bdUV = barrelDistort(uv, barrelStr);

      vec2 suv = scaleUV(bdUV, vec2(scaleX, scaleY));

      if (suv.x < 0.0 || suv.x > 1.0 || suv.y < 0.0 || suv.y > 1.0)
      return vec4(0.0);

      // ── Edge mask (vignette tightens as it collapses) ─────────────
      float edgeSoft = mix(0.14, 0.04, easeInQuad(p));
      float tb   = centerGradient(suv.y);
      float lr   = centerGradient(suv.x);
      float mask = smoothstep(0.0, edgeSoft, tb) * smoothstep(0.0, edgeSoft, lr);

      // ── Chromatic aberration: appears as power dies ───────────────
      float aberrAmt = easeInQuad(p) * 0.020;
      vec4 wR = texture2D(niri_tex, scaleUV(bdUV + vec2( aberrAmt, 0.0), vec2(scaleX, scaleY)));
      vec4 wG = texture2D(niri_tex, suv);
      vec4 wB = texture2D(niri_tex, scaleUV(bdUV - vec2( aberrAmt, 0.0), vec2(scaleX, scaleY)));
      vec4 wColor = vec4(wR.r, wG.g, wB.b, wG.a);

      // ── Desaturation: content loses color as power drops ──────────
      float desat = easeInQuad(p);
      float lum   = dot(wColor.rgb, vec3(0.299, 0.587, 0.114));
      wColor.rgb  = mix(wColor.rgb, vec3(lum), desat * 0.7);

      // ── Phosphor tint: cold blue-white bleeds in at collapse ──────
      vec3 coldTint   = vec3(0.50, 0.78, 1.00);
      float tintAmt   = easeInCubic(p);
      vec3  tintedRGB = mix(wColor.rgb, coldTint, tintAmt * 0.6);

      // ── Phosphor persistence dot ──────────────────────────────────
      // In the last 20% of the close, a bright white dot lingers at center
      float dotPhase = remap(p, 0.78, 1.00);
      float dotDist  = length(uv - 0.5) * 2.0;  // 0 at center, 1 at corner
      // Horizontal 'line' shape: squished vertically
      float dotH     = length(vec2(uv.x-0.5, (uv.y-0.5)*8.0));
      float dotGlow  = smoothstep(0.25, 0.0, dotH) * (1.0 - easeOutExpo(dotPhase));
      vec3  dotColor = vec3(0.85, 0.92, 1.00) * dotGlow * 2.5;

      // ── RGB rainbow sweep (closing) ───────────────────────────────
      // Band sweeps right-to-left as window collapses, fades early
      float rgbFade   = easeOutQuad(remap(inv, 0.15, 0.75));
      float sweepPos  = suv.x - inv * 1.6 + 0.3;
      float bandWidth = 0.22;
      float band      = smoothstep(bandWidth, 0.0, abs(sweepPos)) * rgbFade * 0.50;
      float hueAngle  = sweepPos * PI * 3.0 + inv * PI * 4.0;
      vec3 rgbSweep   = vec3(
      0.5 + 0.5 * sin(hueAngle),
      0.5 + 0.5 * sin(hueAngle + PI * 0.667),
      0.5 + 0.5 * sin(hueAngle + PI * 1.333)
      ) * band;

      // ── Compose ───────────────────────────────────────────────────
      float alpha  = mask * easeOutQuad(inv);

      // Content fades via easeInExpo on the inv side
      float contentBlend = easeInExpo(inv);
      vec4 phosphorLayer = vec4(tintedRGB + dotColor + rgbSweep, alpha * wColor.a);
      vec4 final = mix(phosphorLayer, wColor, contentBlend);
      final.rgb += dotColor + rgbSweep * (1.0 - contentBlend);
      final.a   *= mask;

      // Snap to fully transparent at the very end
      final *= 1.0 - easeInQuart(remap(p, 0.90, 1.00));

      return final;
    }
    "
  }

  horizontal-view-movement {
    spring damping-ratio=0.50 stiffness=800 epsilon=0.0003
  }

  window-movement {
    spring damping-ratio=0.45 stiffness=760 epsilon=0.0003
  }

